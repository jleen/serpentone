{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Keyboard Mode",
            "type": "debugpy",
            "request": "launch",
            "program": "main.py",
            "console": "integratedTerminal",
            "args": "--qwerty",
            "env": {"TEXTUAL": "debug,devtools"},
            "preLaunchTask": "Textual Console"
        },
        {
            "name": "Python Debugger: MIDI Mode",
            "type": "debugpy",
            "request": "launch",
            "program": "main.py",
            "console": "integratedTerminal",
            "args": "--midi=0",
            "env": {"TEXTUAL": "debug,devtools"},
            "preLaunchTask": "Textual Console"
        },
    ]
}